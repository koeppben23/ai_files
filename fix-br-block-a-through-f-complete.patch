+            scanned_surfaces=[
+                CodeSurface(path="src/other.py", language="python", surface_type="other"),
+            ],
+            candidate_count=2,
+            extraction_ran=True,
+            validated_code_rule_count=1,
+            dropped_non_business_surface_count=0,
+            dropped_schema_only_count=0,
+            rejected_non_business_subject_count=0,
+        )
