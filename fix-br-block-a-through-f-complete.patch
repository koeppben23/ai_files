+            dropped_non_business_surface_count=20,
+            dropped_schema_only_count=5,
+            rejected_non_business_subject_count=10,
+        )
+        
+        # Should have missing reasons due to filtering
+        assert len(coverage.missing_surface_reasons) > 0
