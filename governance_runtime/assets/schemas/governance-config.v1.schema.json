{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "governance-config.v1.schema.json",
  "title": "Governance Configuration",
  "description": "Policy knobs for governance behavior. Located at workspace root.",
  "type": "object",
  "required": ["$schema", "review", "pipeline", "regulated"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "const": "governance-config.v1.schema.json"
    },
    "review": {
      "type": "object",
      "description": "Review iteration configuration",
      "required": ["phase5_max_review_iterations", "phase6_max_review_iterations"],
      "additionalProperties": false,
      "properties": {
        "phase5_max_review_iterations": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "description": "Maximum review iterations for Phase 5"
        },
        "phase6_max_review_iterations": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "description": "Maximum review iterations for Phase 6"
        }
      }
    },
    "pipeline": {
      "type": "object",
      "description": "Pipeline mode configuration",
      "required": ["allow_pipeline_mode", "auto_approve_enabled"],
      "additionalProperties": false,
      "properties": {
        "allow_pipeline_mode": {
          "type": "boolean",
          "description": "Whether pipeline mode is allowed"
        },
        "auto_approve_enabled": {
          "type": "boolean",
          "description": "Whether auto-approve is enabled in pipeline mode"
        }
      }
    },
    "regulated": {
      "type": "object",
      "description": "Regulated mode configuration",
      "required": ["allow_auto_approve", "require_governance_mode_active"],
      "additionalProperties": false,
      "properties": {
        "allow_auto_approve": {
          "type": "boolean",
          "description": "Whether auto-approve is allowed in regulated mode (should be false)"
        },
        "require_governance_mode_active": {
          "type": "boolean",
          "description": "Whether governance-mode.json must be active for regulated enforcement"
        }
      }
    }
  }
}
