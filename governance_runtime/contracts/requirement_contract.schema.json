{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "governance-requirement-contract.v1",
  "title": "Governance Requirement Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "criticality",
    "owner_test",
    "live_proof_key",
    "required_behavior",
    "forbidden_behavior",
    "user_visible_expectation",
    "state_expectation",
    "code_hotspots",
    "verification_methods",
    "acceptance_tests",
    "done_rule"
  ],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "title": {"type": "string", "minLength": 1},
    "criticality": {
      "type": "string",
      "enum": ["release_blocking", "important", "normal"]
    },
    "owner_test": {"type": "string", "minLength": 1},
    "live_proof_key": {"type": "string", "minLength": 1},
    "required_behavior": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "forbidden_behavior": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "user_visible_expectation": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "state_expectation": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "code_hotspots": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "verification_methods": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "static_verification",
          "behavioral_verification",
          "user_surface_verification",
          "live_flow_verification",
          "receipts_verification"
        ]
      }
    },
    "acceptance_tests": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "done_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "require_all_verifications_pass",
        "fail_closed_on_missing_evidence",
        "fail_on_forbidden_observation"
      ],
      "properties": {
        "require_all_verifications_pass": {"type": "boolean"},
        "fail_closed_on_missing_evidence": {"type": "boolean"},
        "fail_on_forbidden_observation": {"type": "boolean"}
      }
    }
  }
}
