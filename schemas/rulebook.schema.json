{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://governance.opencode.ai/schemas/rulebook/v1.2.0/rulebook.schema.json",
  "version": "1.2.0",
  "title": "Governance Rulebook",
  "type": "object",
  "required": ["kind", "metadata"],
  "additionalProperties": false,
  "properties": {
    "kind": {
      "type": "string",
      "enum": ["core", "profile"]
    },
    "metadata": { "$ref": "#/$defs/metadata" },
    "precedence": { "$ref": "#/$defs/precedence" },
    "activation": { "$ref": "#/$defs/activation" },
    "phase_integration": { "$ref": "#/$defs/phase_integration" },
    "evidence_contract": { "$ref": "#/$defs/evidence_contract" },
    "patterns": { 
      "type": "array", 
      "items": { "$ref": "#/$defs/pattern" }
    },
    "anti_patterns": { 
      "type": "array", 
      "items": { "$ref": "#/$defs/anti_pattern" }
    },
    "decision_trees": { 
      "type": "array", 
      "items": { "$ref": "#/$defs/decision_tree" }
    },
    "verification_commands": { 
      "type": "array",
      "items": { "$ref": "#/$defs/command" }
    },
    "warning_codes": { 
      "type": "array",
      "items": { "$ref": "#/$defs/warning_code" }
    },
    "references": { 
      "type": "array",
      "items": { "$ref": "#/$defs/typed_reference" }
    },
    "authority_index": { "$ref": "#/$defs/authority_index" },
    "phase_exit_contract": {
      "type": "array",
      "items": { "$ref": "#/$defs/phase_exit_contract_entry" },
      "description": "Per-phase exit conditions with pass criteria, blocking conditions, and evidence freshness requirements."
    },
    "failure_codes": {
      "type": "array",
      "items": { "$ref": "#/$defs/failure_code_ref" },
      "description": "References to canonical reason codes used by this rulebook's blocking conditions."
    }
  },
  "allOf": [
    { 
      "if": { "properties": { "kind": { "const": "core" } } },
      "then": { 
        "required": ["authority_index"],
        "properties": { "authority_index": { "$ref": "#/$defs/authority_index" } }
      }
    },
    {
      "if": { "properties": { "kind": { "const": "profile" } } },
      "then": {
        "not": { "required": ["authority_index"] }
      }
    },
    {
      "if": { 
        "properties": { 
          "metadata": { 
            "properties": { 
              "status": { "const": "active" } 
            } 
          } 
        } 
      },
      "then": {
        "required": ["activation", "phase_integration", "evidence_contract", "verification_commands", "references"]
      }
    }
  ],
  "$defs": {
    "metadata": {
      "type": "object",
      "required": ["id", "name", "version", "status", "schema_version"],
      "additionalProperties": false,
      "properties": {
        "id": { 
          "type": "string",
          "oneOf": [
            { "pattern": "^core\\.(master|rules|bootstrap)$" },
            { "pattern": "^profile\\.[a-z][a-z0-9-]*$" }
          ]
        },
        "name": { "type": "string" },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
        "status": { "type": "string", "enum": ["active", "deprecated"] },
        "schema_version": { 
          "type": "string", 
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Semver of the rulebook.schema.json this document targets."
        },
        "description": {
          "type": "string",
          "default": "",
          "description": "Free-text description of the rulebook purpose and scope."
        }
      }
    },

    "precedence": {
      "type": "object",
      "required": ["rank", "applies_when"],
      "additionalProperties": false,
      "properties": {
        "rank": { "type": "integer" },
        "applies_when": { 
          "oneOf": [
            { "type": "array", "items": { "$ref": "#/$defs/condition" } },
            { 
              "type": "string", 
              "description": "DEPRECATED: Nur für Übergangsphase (Phase A Pilot). Entfernen vor Full Rollout in Phase B."
            }
          ]
        },
        "overrides": { 
          "type": "array", 
          "items": { "type": "string" }
        }
      }
    },

    "activation": {
      "type": "object",
      "required": ["type", "conditions"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["manifest", "detection", "fallback"]
        },
        "conditions": {
          "type": "array",
          "items": { "$ref": "#/$defs/condition" }
        }
      }
    },

    "condition": {
      "type": "object",
      "required": ["field", "operator", "value"],
      "additionalProperties": false,
      "properties": {
        "field": { "type": "string" },
        "operator": { "type": "string", "enum": ["equals", "not_exists", "contains", "regex", "gt", "gte", "lt", "lte"] },
        "value": { "type": ["string", "boolean", "number", "null"] }
      }
    },

    "phase_integration": {
      "type": "object",
      "required": ["phases"],
      "additionalProperties": false,
      "properties": {
        "phases": {
          "type": "array",
          "items": { 
            "type": "string",
            "pattern": "^phase_[0-9](_[0-9])?$"
          }
        },
        "required_outputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "required_checks": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "evidence_contract": {
      "type": "object",
      "required": ["required_artifacts", "required_fields"],
      "additionalProperties": false,
      "properties": {
        "required_artifacts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "required_fields": {
          "type": "array",
          "items": { "type": "string" }
        },
        "acceptance_rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/acceptance_rule" }
        }
      }
    },

    "acceptance_rule": {
      "type": "object",
      "required": ["field", "condition"],
      "additionalProperties": false,
      "properties": {
        "field": { "type": "string" },
        "condition": { 
          "oneOf": [
            { "type": "array", "items": { "$ref": "#/$defs/condition" } },
            { 
              "type": "string", 
              "description": "DEPRECATED: Nur für Übergangsphase (Phase A Pilot). Entfernen vor Full Rollout in Phase B."
            }
          ]
        },
        "error_message": { "type": "string" }
      }
    },

    "command": {
      "type": "object",
      "required": ["cmd", "purpose"],
      "additionalProperties": false,
      "properties": {
        "cmd": { "type": "string" },
        "purpose": { "type": "string" },
        "expected_exit_code": { "type": "integer" },
        "required_for": { "type": "string" }
      }
    },

    "typed_reference": {
      "type": "object",
      "required": ["id", "target", "type"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "target": { "type": "string" },
        "type": { "type": "string", "enum": ["rulebook", "schema", "kernel", "external"] }
      }
    },

    "pattern": {
      "type": "object",
      "required": ["id", "title", "enforces", "code_example"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^PAT-[A-Z0-9-]+$" },
        "title": { "type": "string" },
        "enforces": { 
          "type": "array", 
          "items": { "type": "string" }
        },
        "code_example": { "$ref": "#/$defs/code_block" },
        "rationale": { "type": "string" }
      }
    },

    "anti_pattern": {
      "type": "object",
      "required": ["id", "title", "detects", "recovery"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^AP-[A-Z0-9-]+$" },
        "title": { "type": "string" },
        "detects": { 
          "type": "array", 
          "items": { "type": "string" }
        },
        "recovery": { "type": "string" }
      }
    },

    "decision_tree": {
      "type": "object",
      "required": ["id", "root"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^DT-[A-Z0-9-]+$" },
        "root": { "$ref": "#/$defs/tree_node" }
      }
    },

    "tree_node": {
      "type": "object",
      "required": ["node_type"],
      "additionalProperties": false,
      "properties": {
        "node_type": { "type": "string", "enum": ["condition", "action", "leaf"] },
        "expression": { "type": "string" },
        "yes": { "$ref": "#/$defs/tree_node" },
        "no": { "$ref": "#/$defs/tree_node" },
        "result": { "type": "string" }
      }
    },

    "warning_code": {
      "type": "object",
      "required": ["code", "triggers"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string", "pattern": "^WARN-[A-Z0-9-]+$" },
        "triggers": { 
          "type": "array", 
          "items": { "type": "string" }
        },
        "recovery": { "type": "string" }
      }
    },

    "code_block": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "language": { "type": "string" },
        "code": { "type": "string" }
      }
    },

    "authority_index": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["area", "source"],
            "additionalProperties": false,
            "properties": {
              "area": { "type": "string" },
              "source": { "type": "string" }
            }
          }
        }
      }
    },

    "phase_exit_contract_entry": {
      "type": "object",
      "required": ["phase", "pass_criteria"],
      "additionalProperties": false,
      "properties": {
        "phase": {
          "type": "string",
          "pattern": "^phase_[0-9](_[0-9])?$"
        },
        "pass_criteria": {
          "type": "array",
          "items": { "$ref": "#/$defs/pass_criterion" }
        },
        "blocking_conditions": {
          "type": "array",
          "items": { "$ref": "#/$defs/blocking_condition" }
        },
        "evidence_freshness": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence_freshness_entry" }
        }
      }
    },

    "pass_criterion": {
      "type": "object",
      "required": ["criterion_id", "critical", "evidence_artifact"],
      "additionalProperties": false,
      "properties": {
        "criterion_id": { "type": "string" },
        "critical": { "type": "boolean" },
        "evidence_artifact": { "type": "string" },
        "threshold": { "type": "number", "description": "Static threshold value. Mutually exclusive with threshold_mode." },
        "threshold_mode": {
          "type": "string",
          "enum": ["static", "dynamic_by_risk_tier"],
          "description": "How the threshold is resolved. 'static' uses the threshold field; 'dynamic_by_risk_tier' delegates to threshold_resolver."
        },
        "threshold_resolver": {
          "type": "string",
          "description": "Dot-path to a registered Python resolver function for dynamic thresholds."
        }
      }
    },

    "blocking_condition": {
      "type": "object",
      "required": ["condition_id", "when", "applies_to_severity", "failure_code"],
      "additionalProperties": false,
      "properties": {
        "condition_id": { "type": "string" },
        "when": {
          "type": "string",
          "enum": ["missing", "stale", "below_threshold"]
        },
        "applies_to_severity": {
          "type": "string",
          "enum": ["critical", "non_critical", "all"],
          "description": "Which criteria severity this condition applies to. 'critical' = only critical:true criteria."
        },
        "failure_code": {
          "type": "string",
          "pattern": "^(BLOCKED|NOT_VERIFIED|WARN)-",
          "description": "Must reference a canonical code from reason_codes.py."
        }
      }
    },

    "evidence_freshness_entry": {
      "type": "object",
      "required": ["artifact_kind", "freshness_class"],
      "additionalProperties": false,
      "properties": {
        "artifact_kind": { "type": "string" },
        "freshness_class": {
          "type": "string",
          "enum": ["identity_signal", "preflight_probe", "gate_evidence", "runtime_diagnostic", "operator_provided"],
          "description": "Maps to TTL defaults in evidence_policy.py EVIDENCE_CLASS_DEFAULT_TTL_SECONDS."
        }
      }
    },

    "failure_code_ref": {
      "type": "object",
      "required": ["code"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^(BLOCKED|NOT_VERIFIED|WARN)-",
          "description": "Reference to a canonical reason code. Authority is reason_codes.py."
        }
      }
    }
  }
}
