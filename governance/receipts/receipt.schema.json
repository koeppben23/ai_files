{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "governance-receipt.v1",
  "title": "Governance Receipt",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "receipt_type",
    "requirement_scope",
    "content_digest",
    "rendered_at",
    "render_event_id",
    "gate",
    "session_id",
    "state_revision",
    "source_command"
  ],
  "properties": {
    "receipt_type": {
      "type": "string",
      "enum": [
        "governance_review_presentation_receipt",
        "implementation_presentation_receipt",
        "execution_receipt",
        "verification_receipt"
      ]
    },
    "requirement_scope": {"type": "string", "minLength": 1},
    "content_digest": {"type": "string", "minLength": 16},
    "rendered_at": {"type": "string", "minLength": 20},
    "render_event_id": {"type": "string", "minLength": 1},
    "gate": {"type": "string", "minLength": 1},
    "session_id": {"type": "string", "minLength": 1},
    "state_revision": {"type": "string", "minLength": 1},
    "source_command": {"type": "string", "minLength": 1}
  }
}
