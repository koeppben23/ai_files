#!/bin/sh
set -e
OPENCODE_CONFIG_ROOT="${OPENCODE_CONFIG_ROOT:-$HOME/.config/opencode}"
OPENCODE_REPO_ROOT="${OPENCODE_REPO_ROOT:-}"
COMMANDS_HOME="${OPENCODE_CONFIG_ROOT}/commands"
PYTHONPATH="${COMMANDS_HOME}:${COMMANDS_HOME}/governance:${PYTHONPATH}"
exec "$(command -v python3 || command -v python)" -m governance.entrypoints.bootstrap_preflight_readonly
